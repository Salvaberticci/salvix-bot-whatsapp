# WhatsApp Bot Template - variables de entorno
# Copia este archivo a .env y rellena tus valores reales.
# Nunca publiques tu .env.

# --- GitHub + Coolify ---
GITHUB_TOKEN=
COOLIFY_URL=
COOLIFY_TOKEN=
COOLIFY_PROJECT_UUID=

# --- WhatsApp Cloud API (Meta) ---
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WEBHOOK_DOMAIN=
VERIFY_TOKEN=
META_APP_SECRET=

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# --- Postgres ---
# En Coolify puede llenarse automaticamente durante el deploy.
DATABASE_URL=

# --- Bot ---
HISTORY_WINDOW=10
MAX_PROMPT_TOKENS=6000
MAX_USER_MESSAGE_CHARS=4000
HISTORY_TTL_DAYS=30

# URL opcional para leads calificados: agenda, formulario, landing, checkout, etc.
QUALIFIED_CTA_URL=

# En false, el bot solo responde a mensajes entrantes.
ENABLE_FOLLOW_UPS=false
FOLLOW_UP_MINUTES=10

# Token para POST /reload y /maintenance/reset-contact.
RELOAD_TOKEN=

# --- Panel admin /admin ---
ADMIN_USER=admin
ADMIN_PASSWORD=
SESSION_SECRET=
